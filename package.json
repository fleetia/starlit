{
  "name": "@fleetia/starlit",
  "private": true,
  "version": "1.4.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/prepare-extension.mjs",
    "check": "pnpm lint && pnpm format:check && pnpm typecheck && pnpm test && pnpm build && pnpm test:extension",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:extension": "tsc -p tests/e2e/tsconfig.json --noEmit && playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@fleetia/lagrange": "0.1.1",
    "gifuct-js": "^2.1.2",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@ibm/plex-sans-variable": "0.2.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/react": "^16.3.2",
    "@types/chrome": "^0.0.268",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vanilla-extract/css": "^1.21.1",
    "@vanilla-extract/vite-plugin": "^5.2.4",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "happy-dom": "^20.10.6",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^8.1.4",
    "vitest": "4.1.9"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.14.0"
  }
}
